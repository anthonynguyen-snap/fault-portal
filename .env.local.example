# =========================================================
# FAULT PORTAL — ENVIRONMENT VARIABLES
# =========================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub!
# =========================================================

# --- Google Service Account Credentials ---
# From your Google Cloud service account JSON key file:
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-client-id

# --- Google Sheets ---
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# --- Google Drive ---
# The ID of the root folder for evidence uploads in Google Drive:
# Open the folder in Drive → copy the ID from the URL
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# --- Commslayer (Team Performance page) ---
# Your Commslayer instance URL (no trailing slash):
COMMSLAYER_BASE_URL=https://your-instance.commslayer.com
# Your Commslayer account ID (found in Settings → Account → Account ID):
COMMSLAYER_ACCOUNT_ID=your-account-id
# Your personal API access token (found in Profile → Access Token):
COMMSLAYER_API_TOKEN=your-api-token
# Optional: where customer email clicks should open from the Unfulfilled tab.
# Supported placeholders: {email}, {name}, {order}, {product}
# Example once confirmed from Commslayer:
# COMMSLAYER_EMAIL_COMPOSE_URL_TEMPLATE=https://app.commslayer.com/compose?to={email}&subject=Backorder%20update%20for%20{order}
COMMSLAYER_EMAIL_COMPOSE_URL_TEMPLATE=

# --- Shopify Admin API (Unfulfilled Orders tab) ---
# Create a custom app in Shopify admin: Settings -> Apps and sales channels
# -> Develop apps -> Create an app -> Configure Admin API scopes (enable
# read_orders) -> Install app -> reveal the Admin API access token.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10
# Same store slug, exposed client-side to build "open in Shopify" links
# (the part of your admin URL before .myshopify.com), e.g. "snapwireless".
NEXT_PUBLIC_SHOPIFY_STORE_SLUG=your-store

# Optional: protects /api/shopify/sync from being called by anyone who finds
# the URL. If set, Vercel Cron must send this as an Authorization header
# (Vercel does this automatically when CRON_SECRET is set as a project env var).
CRON_SECRET=replace-with-a-long-random-secret

# --- App Settings ---
# A secret password to protect the portal (simple auth)
PORTAL_PASSWORD=your-secure-password

# Required for secure staff/admin sessions. Use a long random value.
SESSION_SECRET=replace-with-a-long-random-secret

# The public URL of your deployed app (used for redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
