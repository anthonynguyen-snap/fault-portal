# ─────────────────────────────────────────────────────────────────────────────
#  FAULT PORTAL — Environment Variables
#  Copy this file, rename to .env.local, and fill in your values.
#  On Vercel: add each of these in Project Settings > Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Service Account ────────────────────────────────────────────────────
# Paste the ENTIRE contents of your service account JSON key file here,
# as a single line (remove all line breaks).
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"fault-portal@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ── Google Sheets ─────────────────────────────────────────────────────────────
# The long ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# The name of the tab inside your sheet (default: Fault Log)
GOOGLE_SHEET_TAB=Fault Log

# ── Google Drive ──────────────────────────────────────────────────────────────
# The ID of your "Fault Evidence" root folder in Google Drive.
# Find it in the URL when you open the folder:
# https://drive.google.com/drive/folders/THIS_PART_HERE
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_drive_folder_id_here

# ── Google OAuth (for staff sign-in) ─────────────────────────────────────────
# From Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ── NextAuth ──────────────────────────────────────────────────────────────────
# A random secret string — generate one at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=paste_a_random_secret_string_here

# Your portal's live URL (change to your Vercel URL after deploying)
NEXTAUTH_URL=https://your-portal.vercel.app

# ── Access Control ────────────────────────────────────────────────────────────
# Only allow sign-in from these email addresses (comma-separated).
# Leave blank to allow anyone with a Google account.
ALLOWED_EMAILS=staff1@yourcompany.com,staff2@yourcompany.com
